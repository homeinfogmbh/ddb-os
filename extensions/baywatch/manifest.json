{
  "manifest_version": 3,
  "name": "Homeinfo Baywatch",
  "version": "1.0.0",
  "description": "Two-layer hybrid architecture for access control. Whitelist-based access control with network and DOM interception.",
  "icons": {
    "128": "logo.png"
  },
  "permissions": [
    "declarativeNetRequest",
    "scripting",
    "activeTab",
    "tabs",
    "storage",
    "alarms",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://portal.homeinfo.de/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pattern-matcher.js", "content-script.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}